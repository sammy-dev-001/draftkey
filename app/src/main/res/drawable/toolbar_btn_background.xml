<?xml version="1.0" encoding="utf-8"?>
<!--
    toolbar_btn_background.xml — Keyboard-matching dark button style.
    Mirrors the modifier key look: dark rounded rect, slightly lighter on press.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed: match COLOR_KEY_PRESSED -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#4A4A4C" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Default: match COLOR_KEY_MODIFIER -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2C2C2E" />
            <corners android:radius="8dp" />
        </shape>
    </item>

</selector>
