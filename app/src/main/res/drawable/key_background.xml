<?xml version="1.0" encoding="utf-8"?>
<!--
    key_background.xml — StateListDrawable for individual keys

    A StateListDrawable shows different visuals depending on the view's state.
    Android checks states from top to bottom and uses the first match.

    States used:
    - state_pressed="true"  → User is currently holding this key
    - (no state)            → Default / unpressed
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESSED: Highlight with accent blue, slightly lighter -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1A4A8A" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#4FC3F7" />
        </shape>
    </item>

    <!-- DEFAULT: Dark navy tile -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#16213E" />
            <corners android:radius="8dp" />
        </shape>
    </item>

</selector>
