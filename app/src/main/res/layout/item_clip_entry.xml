<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:layout_margin="4dp"
    android:background="@drawable/clip_entry_background"
    android:clipChildren="true">

    <!-- Clip image preview -->
    <ImageView
        android:id="@+id/iv_clip_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Clip text preview -->
    <TextView
        android:id="@+id/tv_clip_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textColor="#E8E8F0"
        android:textSize="11sp"
        android:maxLines="6"
        android:ellipsize="end"
        android:padding="8dp"
        android:lineSpacingExtra="1dp" />

    <!-- Bottom Action Row Overlay -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#66000000"
        android:paddingHorizontal="4dp"
        android:paddingVertical="2dp">

        <!-- Delete -->
        <TextView
            android:id="@+id/btn_clip_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:padding="4dp" />

        <!-- Pin -->
        <TextView
            android:id="@+id/btn_clip_pin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="📌"
            android:textSize="14sp"
            android:padding="4dp" />

    </RelativeLayout>
</FrameLayout>
