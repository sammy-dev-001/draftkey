<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="42dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp">

    <TextView
        android:id="@+id/btn_clipboard_bar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="4dp"
        android:text="📋"
        android:textSize="18sp"
        android:gravity="center"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Clipboard" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/tv_suggest_0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#C4C7C4"
            android:fontFamily="@font/hanken_grotesk"
            android:textSize="14sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:background="?android:attr/selectableItemBackground" />

        <TextView
            android:id="@+id/tv_suggest_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#E5E2E1"
            android:textStyle="bold"
            android:fontFamily="@font/hanken_grotesk"
            android:textSize="15sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:background="?android:attr/selectableItemBackground" />

        <TextView
            android:id="@+id/tv_suggest_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#C4C7C4"
            android:fontFamily="@font/hanken_grotesk"
            android:textSize="14sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:background="?android:attr/selectableItemBackground" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_settings"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="4dp"
        android:src="@drawable/ic_settings"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Settings"
        android:alpha="0.7" />
</merge>
