<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Setup / onboarding screen

    This is what users see when they open DraftKeys from their home screen.
    It guides them through enabling the keyboard in system settings.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/keyboard_background"
    android:gravity="center"
    android:padding="32dp">

    <!-- App Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎹"
        android:textSize="72sp" />

    <!-- App Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DraftKeys"
        android:textColor="@color/accent_blue"
        android:textSize="34sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <!-- Tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Never lose a message again."
        android:textColor="#AAAAAA"
        android:textSize="16sp"
        android:layout_marginTop="8dp" />

    <!-- Divider -->
    <View
        android:layout_width="80dp"
        android:layout_height="2dp"
        android:background="@color/accent_blue"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp" />

    <!-- Step instructions -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 1: Enable DraftKeys in keyboard settings\nStep 2: Set DraftKeys as your default keyboard\nStep 3: Open any app and start typing!"
        android:textColor="@color/key_text"
        android:textSize="14sp"
        android:lineSpacingExtra="6dp"
        android:gravity="center" />

    <!-- Status text (updated dynamically) -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checking status..."
        android:textColor="@color/key_text"
        android:textSize="14sp"
        android:layout_marginTop="24dp"
        android:textStyle="bold" />

    <!-- Button to open system keyboard settings -->
    <Button
        android:id="@+id/btn_enable_keyboard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Open Keyboard Settings"
        android:backgroundTint="@color/accent_blue"
        android:textColor="#0D1117"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="32dp"
        android:paddingVertical="12dp" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Keyboard Settings"
        android:backgroundTint="#363638"
        android:textColor="#E3E2E0"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="32dp"
        android:paddingVertical="12dp" />

</LinearLayout>
